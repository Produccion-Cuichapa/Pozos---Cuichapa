<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover">
<title>UPV – Unidades de Producción</title>
<link rel="manifest" href="./manifest.json">
<meta name="theme-color" content="#1a3a5c">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="UPV">
<!-- CSS propio — no comparte hoja de estilos con la app de recorredores -->
<link rel="stylesheet" href="./css/upv.css">
</head>
<body>

<!-- ═══════════════════════════════════════════════════════
     PANTALLA DE ACCESO — selección de empresa
═══════════════════════════════════════════════════════ -->
<div id="screen-login" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:24px;gap:0;background:var(--bg)">
  <div class="login-logo">UPV</div>
  <div class="login-sub">Unidades de Producción y Volumen<br>Campo Cuichapa U-39</div>
  <div class="login-title">Selecciona tu empresa</div>
  <div class="login-btns">
    <button class="empresa-btn" data-empresa="PETROSMART">🔵 PETROSMART</button>
    <button class="empresa-btn" data-empresa="ATO">🟢 ATO</button>
    <button class="empresa-btn" data-empresa="IPEP">🟡 IPEP</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     APP PRINCIPAL — visible después de seleccionar empresa
═══════════════════════════════════════════════════════ -->
<div id="upv-app" style="display:none;height:100%">

  <!-- Header -->
  <div id="upv-header" style="position:sticky;top:0;z-index:5">
    <div>
      <div class="fs13 txt2">Empresa activa</div>
      <div id="upv-empresa-label" class="header-empresa"></div>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <div id="upv-conn-badge" class="conn-badge">EN LÍNEA</div>
      <button onclick="cerrarSesion()" title="Cambiar empresa"
              style="background:none;border:none;color:var(--txt2);font-size:18px;cursor:pointer;padding:4px">↩</button>
    </div>
  </div>

  <!-- Contenedor principal con sidebar -->
  <div id="upv-main-layout" style="display:flex;flex:1;overflow:hidden">

    <!-- Área de contenido -->
    <div id="upv-content">

      <!-- ── SCREEN: UPV (formulario + historial) ── -->
      <div id="screen-upv" class="upv-screen active">

        <!-- Formulario principal -->
        <div id="upv-form-principal">
          <!-- Unidad -->
          <div class="upv-card">
            <div class="upv-label">Unidad (número de pipa)</div>
            <input id="upv-unidad" type="text" inputmode="numeric"
                   class="upv-input" placeholder="Ej: 124">
          </div>

          <!-- ¿QUÉ HARÁS? -->
          <div class="upv-card">
            <div class="upv-label">¿QUÉ HARÁS?</div>
            <div class="tipo-btns">
              <button class="tipo-btn" data-tipo="CARGA">⬇️ CARGA</button>
              <button class="tipo-btn" data-tipo="DESCARGA">⬆️ DESCARGA</button>
            </div>
          </div>

          <!-- Campos dinámicos según selección -->
          <div id="campos-dinamicos"></div>
        </div>

        <!-- Vista previa (oculta hasta TÉRMINO) -->
        <div id="upv-preview" style="display:none"></div>

        <!-- Separador -->
        <div class="upv-sep"></div>

        <!-- Historial local -->
        <div class="upv-label" style="padding:0 0 8px">Reportes recientes</div>
        <div id="upv-historial"></div>
      </div>

      <!-- ── SCREEN: OBSERVACIONES ── -->
      <div id="screen-observaciones" class="upv-screen">
        <div class="upv-card" style="border-color:var(--accent2);margin-bottom:16px">
          <div class="upv-label" style="color:var(--accent2)">📋 Observaciones</div>
        </div>

        <!-- Unidad -->
        <div class="upv-card">
          <div class="upv-label">Unidad</div>
          <input id="obs-unidad" type="text" inputmode="numeric"
                 class="upv-input" placeholder="Número de pipa">
        </div>

        <!-- Texto de observación -->
        <div class="upv-card">
          <div class="upv-label">Observación</div>
          <textarea id="obs-texto" class="upv-input" rows="4"
                    placeholder="Describe la situación..."
                    style="resize:none;height:auto"></textarea>
        </div>

        <!-- Tipo de observación -->
        <div class="upv-card">
          <div class="upv-label">Tipo</div>
          <select id="obs-tipo" class="upv-select">
            <option value="normal">Observación normal</option>
            <option value="incidencia">⚠️ Incidencia prioritaria</option>
          </select>
        </div>

        <!-- Fotos provisional -->
        <div class="upv-card">
          <div class="upv-label">Fotografías</div>
          <div class="fotos-mock" onclick="agregarFotosUpv()">
            <span class="cam-icon">📸</span>
            <span>Toca para agregar fotos (próximamente)</span>
          </div>
        </div>

        <!-- GPS provisional -->
        <div class="upv-card">
          <div class="upv-label">GPS</div>
          <div class="gps-mock" id="obs-gps-status">
            <div class="gps-dot"></div>
            <span>Ubicación: esperando señal...</span>
          </div>
        </div>

        <button id="btn-guardar-obs" class="upv-btn mt12">💾 GUARDAR OBSERVACIÓN</button>
      </div>

    </div><!-- /upv-content -->

    <!-- Sidebar navegación lateral derecha -->
    <nav id="upv-nav">
      <button class="nav-btn active" data-screen="upv">
        <span class="nav-icon">🚛</span>
        UPV
      </button>
      <button class="nav-btn" data-screen="observaciones">
        <span class="nav-icon">📋</span>
        OBS
      </button>
    </nav>

  </div><!-- /upv-main-layout -->

</div><!-- /upv-app -->

<!-- JS propio — no comparte scripts con la app de recorredores -->
<script src="./js/upv.js"></script>
</body>
</html>
